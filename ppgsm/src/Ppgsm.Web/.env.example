# Live mode uses MSAL authorization code flow with PKCE and an API bearer token.
VITE_DATA_ADAPTER=live

# Required in live mode. These values are public identifiers, not secrets.
VITE_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/organizations
VITE_API_SCOPE=api://00000000-0000-0000-0000-000000000000/ppgsm.read

# Explicit local review mode. Never set in production.
# VITE_DATA_ADAPTER=mock